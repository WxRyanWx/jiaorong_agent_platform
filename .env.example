# GitHub OAuth Configuration for GitHub Copilot
# Copy this file to .env and fill in the actual values
# Both Client ID and Client Secret are required
VITE_GITHUB_CLIENT_ID=Iv1.b507a08c87ecfe98
VITE_GITHUB_CLIENT_SECRET=your_github_client_secret_here
VITE_GITHUB_REDIRECT_URI=https://deepchatai.cn/auth/github/callback
VITE_LOG_IPC_CALL=0

# 开发模式下生命周期 hook 之间的延迟（毫秒），0 表示不延迟
VITE_APP_LIFECYCLE_HOOK_DELAY=0

# 桥接登录 API 生产环境根地址（默认 https://c4ai.ccccltd.cn，开发与打包统一）
VITE_AUTH_API_ORIGIN=https://c4ai.ccccltd.cn
VITE_PROVIDER_DB_URL=https://raw.githubusercontent.com/ThinkInAIXYZ/PublicProviderConf/refs/heads/dev/dist/all.json
